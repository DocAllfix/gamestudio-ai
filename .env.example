# ====================================================================
# Game Studio AI — .env.example
#
# Copy to .env and fill the values. Never commit .env.
# Each section names which workstream(s) need the key.
# ====================================================================

# --------------------------------------------------------------------
# Phase 1 — RAG ingestion (already used by scripts/ingestion/*)
# --------------------------------------------------------------------
GITHUB_TOKEN=
GITLAB_TOKEN=

# --------------------------------------------------------------------
# Supabase (every workstream — DB + RPC + RLS)
# --------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=5432
SUPABASE_DB_USER=
SUPABASE_DB_PASSWORD=
SUPABASE_DB_NAME=postgres

# --------------------------------------------------------------------
# LLM providers
# OpenAI + DeepSeek + Anthropic + Gemini are used by Phase 1 ingestion
# AND by W2's LLM router (lib/llm/router.ts) in Phase 2.
# OpenRouter is the default gateway in Phase 2.
# --------------------------------------------------------------------
OPENROUTER_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --------------------------------------------------------------------
# Azure OpenAI (alternative path to OpenRouter — used when W2's router
# wants Azure-hosted gpt-4.1-mini / gpt-4o etc. with private endpoint).
#
# ENDPOINT is the resource root:
#   https://<resource>.openai.azure.com
# V1_ENDPOINT is the new OpenAI-compatible base:
#   https://<resource>.openai.azure.com/openai/v1
# DEPLOYMENT is the deployment NAME you create in the Azure portal
# (NOT the model id from the catalog). Pick the same name as the
# model so the env stays human-readable, e.g. "gpt-4.1-mini".
# API_VERSION example: 2024-10-21
# KEY_FALLBACK is the "Key 2" Azure provisions automatically — keep
# it in env so the router can rotate when Key 1 hits a 401.
# --------------------------------------------------------------------
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_KEY_FALLBACK=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_V1_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=

# --------------------------------------------------------------------
# Helicone (W2 LLM observability proxy)
# --------------------------------------------------------------------
HELICONE_API_KEY=

# --------------------------------------------------------------------
# Generative media providers (W2)
# --------------------------------------------------------------------
REPLICATE_API_TOKEN=
SUNO_API_KEY=
ELEVENLABS_API_KEY=
MESHY_API_KEY=
FREESOUND_API_KEY=

# --------------------------------------------------------------------
# Cloudflare R2 (W3 .zip artifact storage)
# R2_ENDPOINT example: https://<account_id>.r2.cloudflarestorage.com
# --------------------------------------------------------------------
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=

# --------------------------------------------------------------------
# E2B sandbox (W3 sandboxed engine builds)
# --------------------------------------------------------------------
E2B_API_KEY=

# --------------------------------------------------------------------
# Trigger.dev (W1 Hermes outer loop + W3 long jobs)
# --------------------------------------------------------------------
TRIGGER_API_KEY=
TRIGGER_PROJECT_REF=

# --------------------------------------------------------------------
# Upstash Redis (W2 per-tool rate limiting + cost cap)
# --------------------------------------------------------------------
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# --------------------------------------------------------------------
# Clerk authentication (W4)
# --------------------------------------------------------------------
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# --------------------------------------------------------------------
# Stripe billing (W4)
# --------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --------------------------------------------------------------------
# PostHog analytics + feature flags (W4)
# POSTHOG_HOST default: https://us.i.posthog.com
# --------------------------------------------------------------------
POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_KEY=
POSTHOG_HOST=

# --------------------------------------------------------------------
# Notifications (W4)
# --------------------------------------------------------------------
RESEND_API_KEY=
LOOPS_API_KEY=
KNOCK_API_KEY=
CRISP_WEBSITE_ID=
DUB_API_KEY=

# --------------------------------------------------------------------
# Error tracking (W4, Phase 2)
# --------------------------------------------------------------------
SENTRY_DSN=

# --------------------------------------------------------------------
# Next.js public app URL — used in OAuth callbacks + Stripe success
# URLs. In dev: http://localhost:3000 ; in prod: https://gamestudio.ai
# --------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=

# --------------------------------------------------------------------
# Hugging Face token for fetching LoRA models (optional, used by some
# W2 sprite generators that hot-swap LoRA weights).
# --------------------------------------------------------------------
HF_TOKEN=
# --------------------------------------------------------------------
# World Labs Marble (W3 — WorldGenPort). Paid API account; internal test
# only at day-1 (user-facing generation requires a custom Order Form —
# see docs/COMPETITIVE_LANDSCAPE_2026.md §6). ~$1.20/world.
# --------------------------------------------------------------------
WORLDLABS_API_KEY=
# --------------------------------------------------------------------
# Langfuse (observability, Phase 2 — Telemetry port). Self-host (MIT) or
# cloud. Replaces Helicone (maintenance mode). In testing, tool_executions
# + Azure Monitor suffice; wire Langfuse when granular tracing is needed.
# --------------------------------------------------------------------
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
