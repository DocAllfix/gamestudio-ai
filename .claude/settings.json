{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "[Console]::OutputEncoding = [System.Text.Encoding]::UTF8; Get-Content -Raw -Encoding UTF8 'c:\\Users\\user\\gamestudio.ai\\CLAUDE.md'",
            "timeout": 15,
            "statusMessage": "Loading CLAUDE.md into session context"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "[Console]::OutputEncoding = [System.Text.Encoding]::UTF8; Get-Content -Raw -Encoding UTF8 'c:\\Users\\user\\gamestudio.ai\\CLAUDE.md'",
            "timeout": 15,
            "statusMessage": "Re-injecting CLAUDE.md before compaction"
          }
        ]
      }
    ]
  }
}
